{
  "name": "imagin-ai",
  "version": "0.6.0",
  "description": "A desktop application for controlling AI image/video/music generation APIs through a dedicated GUI.",
  "main": "dist/main/index.js",
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=4.0.0",
    "npm": "please-use-yarn",
    "pnpm": "please-use-yarn"
  },
  "scripts": {
    "dev": "concurrently -k -r \"yarn run dev:main\" \"yarn run dev:renderer\" \"yarn run dev:electron\"",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:renderer": "vite",
    "dev:electron": "wait-on dist/main/index.js http://localhost:3001 && electron . --dev",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "format": "prettier --write \"src/**/*.{ts,js,css,json}\"",
    "lint": "tsc --noEmit",
    "dist:win": "yarn build && electron-builder --win --publish=never",
    "dist:mac": "yarn build && electron-builder --mac --publish=never",
    "dist:linux": "yarn build && electron-builder --linux --publish=never",
    "release:win": "yarn build && electron-builder --win --publish=always",
    "release:mac": "yarn build && electron-builder --mac --publish=always",
    "release:linux": "yarn build && electron-builder --linux --publish=always",
    "clean": "rimraf dist release node_modules/.cache"
  },
  "keywords": [
    "imagin-ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.10.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^2.2.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "archiver": "^7.0.1",
    "electron-updater": "^6.8.5",
    "ffmpeg-static": "^5.3.0",
    "i18next": "^26.1.0",
    "openai": "^6.37.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^7.15.0",
    "uuid": "^14.0.0",
    "xml2js": "^0.6.2",
    "zustand": "^5.0.13"
  }
}
